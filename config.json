{
    "_comment": "手势识别项目配置文件 - 根据平台自动选择合适的配置",
    
    "common": {
        "data_dir": "dataset",
        "checkpoint_dir": "checkpoint",
        "num_frames": 8,
        "img_size": [100, 176],
        "num_classes": 27,
        "hidden_dim": 256,
        "learning_rate": 0.01,
        "normalize_mean": [0.485, 0.456, 0.406],
        "normalize_std": [0.229, 0.224, 0.225]
    },
    
    "windows": {
        "batch_size": 16,
        "num_workers": 6,
        "pin_memory": true,
        "prefetch_factor": 2,
        "num_epochs": 20
    },
    
    "linux": {
        "batch_size": 64,
        "num_workers": 16,
        "pin_memory": true,
        "prefetch_factor": 4,
        "num_epochs": 50
    }
}
